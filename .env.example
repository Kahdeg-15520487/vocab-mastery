# Backend
DATABASE_URL=postgresql://vocab_user:vocab_pass@localhost:5432/vocab_master
NODE_ENV=development
PORT=7101

# JWT Authentication
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Google OAuth (optional - for Google Sign-in)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:7101/api/auth/google/callback

# Frontend
VITE_API_URL=http://localhost:7101/api

# PostgreSQL (for docker-compose)
POSTGRES_DB=vocab_master
POSTGRES_USER=vocab_user
POSTGRES_PASSWORD=vocab_pass
