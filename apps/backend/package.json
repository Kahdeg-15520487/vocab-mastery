{
  "name": "@vocab-master/backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:prod": "node dist/server.js",
    "migrate": "prisma migrate dev",
    "migrate:prod": "prisma migrate deploy",
    "generate": "prisma generate",
    "seed": "tsx prisma/seed.ts",
    "import:oxford": "tsx prisma/import-oxford.ts",
    "crawl": "tsx src/crawler/index.ts",
    "crawl:batch": "tsx src/crawler/index.ts --batch=100",
    "crawl:dry": "tsx src/crawler/index.ts --dry-run",
    "export": "tsx src/scripts/export.ts",
    "import": "tsx src/scripts/import.ts",
    "studio": "prisma studio"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/oauth2": "^8.2.0",
    "@prisma/client": "^5.22.0",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "cheerio": "^1.2.0",
    "fastify": "^4.26.2",
    "jsonwebtoken": "^9.0.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.30",
    "prisma": "^5.12.0",
    "tsx": "^4.7.1",
    "typescript": "^5.4.3"
  }
}
