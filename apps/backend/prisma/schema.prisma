generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum Role {
  LEARNER
  ADMIN
}

enum SubscriptionTier {
  FREE      // Learner - $0
  EXPLORER  // Explorer - $4.99/mo
  WORDSMITH // Wordsmith - $9.99/mo
}

enum ProgressStatus {
  NEW
  LEARNING
  REVIEWING
  MASTERED
}

// ============================================
// USER & AUTH
// ============================================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String?  @map("password_hash")
  username      String   @unique
  role          Role     @default(LEARNER)
  
  // OAuth
  googleId      String?  @unique @map("google_id")
  
  // Subscription
  subscriptionTier      SubscriptionTier @default(FREE) @map("subscription_tier")
  subscriptionExpiresAt DateTime?        @map("subscription_expires_at")
  
  // Timestamps
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  lastLoginAt   DateTime? @map("last_login_at")
  
  // Relations
  refreshTokens    RefreshToken[]
  userProgress     UserProgress[]
  dailyGoals       DailyGoal[]
  streak           UserStream?
  achievements     UserAchievement[]
  studyLists       StudyList[]
  
  @@index([email])
  @@index([googleId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  revoked   Boolean  @default(false)
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ============================================
// SYSTEM CONFIG
// ============================================

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([key])
  @@map("system_config")
}

// ============================================
// USER PROGRESS & ACHIEVEMENTS
// ============================================

model UserProgress {
  id           String         @id @default(cuid())
  userId       String         @map("user_id")
  themeId      String?        @map("theme_id")
  cefrLevel    String         @map("cefr_level")  // A1, A2, B1, B2, C1, C2
  status       ProgressStatus @default(NEW)
  
  // SM-2 algorithm fields
  interval     Int            @default(0)        // Days until next review
  easeFactor   Float          @default(2.5)      @map("ease_factor")
  repetitions  Int            @default(0)        // Consecutive correct reviews
  
  // Review tracking
  nextReview   DateTime       @default(now())    @map("next_review")
  lastReview   DateTime?      @map("last_review")
  totalReviews Int            @default(0)        @map("total_reviews")
  
  // Stats for this level
  wordsLearned Int            @default(0)        @map("words_learned")
  wordsMastered Int           @default(0)        @map("words_mastered")
  
  createdAt    DateTime       @default(now())    @map("created_at")
  updatedAt    DateTime       @updatedAt         @map("updated_at")
  
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, cefrLevel, themeId])
  @@index([userId])
  @@index([nextReview])
  @@index([status])
  @@map("user_progress")
}

model DailyGoal {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  date           DateTime
  
  // Targets
  wordsToLearn   Int      @default(10)    @map("words_to_learn")
  wordsToReview  Int      @default(20)    @map("words_to_review")
  
  // Actuals
  wordsLearned   Int      @default(0)     @map("words_learned")
  wordsReviewed  Int      @default(0)     @map("words_reviewed")
  
  completed      Boolean  @default(false)
  completedAt    DateTime?                @map("completed_at")
  
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt      @map("updated_at")
  
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@map("daily_goals")
}

model UserStream {
  id                 String   @id @default(cuid())
  userId             String   @unique @map("user_id")
  
  currentStreak      Int      @default(0)    @map("current_streak")
  longestStreak      Int      @default(0)    @map("longest_streak")
  lastActivityDate   DateTime?                @map("last_activity_date")
  
  // Grace period system (2 per month allowed)
  gracePeriodsUsed   Int      @default(0)    @map("grace_periods_used")
  gracePeriodMonth   Int?                     @map("grace_period_month")  // YYYYMM format
  
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt      @map("updated_at")
  
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([lastActivityDate])
  @@map("user_streaks")
}

model Achievement {
  id              String   @id @default(cuid())
  key             String   @unique          // e.g., "first_word", "streak_7"
  name            String
  description     String
  icon            String                     // Emoji or icon name
  category        String                     // "learning", "streak", "social", etc.
  
  // Condition to unlock
  conditionType   String                     @map("condition_type")   // "words_learned", "streak_days", etc.
  conditionValue  Int                        @map("condition_value")  // Threshold value
  
  // XP reward
  xpReward        Int      @default(0)      @map("xp_reward")
  
  createdAt       DateTime @default(now())  @map("created_at")
  
  userAchievements UserAchievement[]
  
  @@index([category])
  @@map("achievements")
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String      @map("user_id")
  achievementId String      @map("achievement_id")
  unlockedAt    DateTime    @default(now())    @map("unlocked_at")
  
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  
  @@unique([userId, achievementId])
  @@index([userId])
  @@index([unlockedAt])
  @@map("user_achievements")
}

// ============================================
// WORDS & THEMES
// ============================================

model Word {
  id            String        @id @default(uuid())
  word          String        @unique
  phoneticUs    String        @map("phonetic_us")
  phoneticUk    String        @map("phonetic_uk")
  partOfSpeech  Json          @map("part_of_speech")
  definition    String
  examples      Json
  synonyms      Json
  antonyms      Json
  oxfordList    String        @map("oxford_list")
  cefrLevel     String        @map("cefr_level")
  frequency     Int
  themes        WordTheme[]
  progress      WordProgress[]
  sessionWords  SessionWord[]
  listWords     StudyListWord[]
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@index([word])
  @@index([cefrLevel])
  @@index([oxfordList])
  @@map("words")
}

model Theme {
  id          String      @id @default(uuid())
  name        String      @unique
  slug        String      @unique
  icon        String
  description String
  words       WordTheme[]
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@map("themes")
}

model WordTheme {
  wordId    String
  themeId   String
  word      Word      @relation(fields: [wordId], references: [id], onDelete: Cascade)
  theme     Theme     @relation(fields: [themeId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now()) @map("created_at")

  @@id([wordId, themeId])
  @@index([themeId])
  @@map("word_themes")
}

model WordProgress {
  id              String    @id @default(uuid())
  wordId          String    @map("word_id")
  word            Word      @relation(fields: [wordId], references: [id], onDelete: Cascade)
  status          String    @default("new")
  interval        Int       @default(0)
  easeFactor      Float     @default(2.5) @map("ease_factor")
  repetitions     Int       @default(0)
  nextReview      DateTime  @default(now()) @map("next_review")
  lastReview      DateTime? @map("last_review")
  totalReviews    Int       @default(0) @map("total_reviews")
  correctReviews  Int       @default(0) @map("correct_reviews")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([wordId])
  @@index([nextReview])
  @@index([status])
  @@map("word_progress")
}

model LearningSession {
  id            String        @id @default(uuid())
  type          String
  themeId       String?       @map("theme_id")
  startedAt     DateTime      @default(now()) @map("started_at")
  completedAt   DateTime?     @map("completed_at")
  totalCorrect  Int           @default(0) @map("total_correct")
  totalIncorrect Int          @default(0) @map("total_incorrect")
  sessionWords  SessionWord[]
  createdAt     DateTime      @default(now()) @map("created_at")

  @@index([startedAt])
  @@map("learning_sessions")
}

model SessionWord {
  id            String          @id @default(uuid())
  sessionId     String          @map("session_id")
  session       LearningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  wordId        String          @map("word_id")
  word          Word            @relation(fields: [wordId], references: [id], onDelete: Cascade)
  shown         Boolean         @default(false)
  response      String?
  responseTime  Int?            @map("response_time")
  createdAt     DateTime        @default(now()) @map("created_at")

  @@index([sessionId])
  @@index([wordId])
  @@map("session_words")
}

model UserStats {
  id              String   @id @default(uuid())
  totalWords      Int      @default(0) @map("total_words")
  masteredWords   Int      @default(0) @map("mastered_words")
  currentStreak   Int      @default(0) @map("current_streak")
  longestStreak   Int      @default(0) @map("longest_streak")
  lastActiveDate  DateTime @default(now()) @map("last_active_date")
  totalXP         Int      @default(0) @map("total_xp")
  level           Int      @default(1)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("user_stats")
}

// ============================================
// STUDY LISTS
// ============================================

model StudyList {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  name        String
  description String?
  color       String   @default("#6366f1")  // Tailwind indigo-500
  icon        String   @default("📚")
  isSystem    Boolean  @default(false)      @map("is_system")
  isPinned    Boolean  @default(false)      @map("is_pinned")
  wordCount   Int      @default(0)          @map("word_count")
  createdAt   DateTime @default(now())      @map("created_at")
  updatedAt   DateTime @updatedAt           @map("updated_at")
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  words       StudyListWord[]
  sharedWith  SharedList[]
  
  @@index([userId])
  @@index([isPinned])
  @@map("study_lists")
}

model StudyListWord {
  id        String    @id @default(cuid())
  listId    String    @map("list_id")
  wordId    String    @map("word_id")
  addedAt   DateTime  @default(now()) @map("added_at")
  
  list      StudyList @relation(fields: [listId], references: [id], onDelete: Cascade)
  word      Word      @relation(fields: [wordId], references: [id], onDelete: Cascade)
  
  @@unique([listId, wordId])
  @@index([listId])
  @@index([wordId])
  @@map("study_list_words")
}

model SharedList {
  id          String   @id @default(cuid())
  listId      String   @map("list_id")
  sharedBy    String   @map("shared_by")
  sharedWith  String   @map("shared_with")
  createdAt   DateTime @default(now()) @map("created_at")
  
  list        StudyList @relation(fields: [listId], references: [id], onDelete: Cascade)
  
  @@unique([listId, sharedWith])
  @@index([listId])
  @@index([sharedWith])
  @@index([sharedBy])
  @@map("shared_lists")
}
